{
    "manifest_version": 2,
    "name": "Firefox Home - Angular",
    "version": "1.0.0",
    "description": "home page made with angular for firefox new tab",
    "browser_specific_settings": {
        "gecko": {
            "id": "firefox-home@lgarbayo",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "telemetry": {
                    "access_type": "collection",
                    "name": "Usage data",
                    "description": "No usage or telemetry data is collected or transmitted.",
                    "link": "https://github.com/lgarbayo/firefox-home",
                    "required": false
                }
            }
        },
        "gecko_android": {
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "telemetry": {
                    "access_type": "collection",
                    "name": "Usage data",
                    "description": "No usage or telemetry data is collected or transmitted.",
                    "link": "https://github.com/lgarbayo/firefox-home",
                    "required": false
                }
            }
        }
    },
    "chrome_url_overrides": {
        "newtab": "newtab/index.html"
    },
    "permissions": [],
    "web_accessible_resources": [
        "newtab/*"
    ]
}
